---
provisioner:
  name: <%= @provisioner %>

platforms:
<% @providers.each do |provider| -%>
- name: <%= "#{@boxname}-#{@arch}-#{provider['name']}" %>
  driver:
    name: vagrant
    provider: <%= provider['name'] %>
    vm_hostname: bento-test
    box: bento-<%= @boxname %>
    box_url: file://<%= Dir.pwd %>/builds/build_complete/<%= provider['file'] %>
    box_arch: <%= @arch %>
    synced_folders:
      - [".", "/vagrant", "disabled: true"]
<% if provider['name'] == 'libvirt' -%>
    provider_raw_config_args:
      - "inputs = [{type: 'mouse', bus: 'usb'}, {type: 'keyboard', bus: 'usb'}]"
      - "usb_controller model: 'qemu-xhci'"
<% end -%>
<% end -%>
suites:
- name: default
