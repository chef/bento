---
provisioner:
  name: <%= @provisioner %>

platforms:
<% @providers.each do |provider| -%>
- name: <%= "#{@boxname.tr('.', '')}-#{@arch}-#{provider['name'].tr('_', '-')}" %>
  driver:
    name: vagrant
    provider: <%= provider['name'] %>
    vm_hostname: bento-test
    box: bento-<%= @boxname %>
    box_url: file://<%= Dir.pwd %>/builds/build_complete/<%= provider['file'] %>
    box_arch: <%= @arch %>
    synced_folders:
      - [".", "/vagrant", "disabled: true"]
<% if provider['name'] == 'libvirt' -%>
    customize:
      inputs: []
<% end -%>
<% end -%>
suites:
- name: default
